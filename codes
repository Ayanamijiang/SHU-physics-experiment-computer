    style.theme_use('clam')
    bg_color = "#f5f7fa"
    fg_color = "#1e2a3e"
    style.configure('.', background=bg_color, foreground=fg_color, font=('微软雅黑', 10))
    style.configure('TLabel', background=bg_color, foreground=fg_color)
    style.configure('TFrame', background=bg_color)
    style.configure('TLabelframe', background=bg_color, foreground=fg_color,
                    relief='flat', borderwidth=1, bordercolor='#e2e8f0')
    style.configure('TLabelframe.Label', background=bg_color, foreground='#1e466e', font=('微软雅黑', 10, 'bold'))
    style.configure('TButton', background='#ffffff', foreground=fg_color, borderwidth=1,
                    relief='flat', padding=6, font=('微软雅黑', 10, 'bold'))
    style.map('TButton', background=[('active', '#e2e8f0'), ('pressed', '#cbd5e1')])
    style.configure('TCheckbutton', background=bg_color, foreground=fg_color, font=('微软雅黑', 10))
    style.configure('TNotebook', background=bg_color, borderwidth=0)
    style.configure('TNotebook.Tab', background='#e2e8f0', padding=[10, 4], font=('微软雅黑', 10))
    style.map('TNotebook.Tab', background=[('selected', '#ffffff')])
    return style


